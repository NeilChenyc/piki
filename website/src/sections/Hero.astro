---
import Button from '../components/Button.astro';
import SVGVisual from '../components/SVGVisual.astro';
---
<section class="hero">
  <div class="container text-center">
    <div class="hero__brand fade-in">
      <img src="/brand-logo.png" alt="Piki" class="hero__logo" width="600" height="400" />
    </div>
    <p class="hero__tagline">你的 LLM Wiki 客户端</p>
    <p class="hero__subtitle">
      AI 维护你的个人知识库。你只管输入和提问。
    </p>
    <div class="hero__cta">
      <Button href="https://github.com/NeilChenyc/piki/releases/latest/download/Piki.app.zip">免费下载 macOS 版</Button>
    </div>
    <SVGVisual alt="碎片信息编译为结构化 Wiki">
      <svg viewBox="0 0 480 290" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Layered card shadow: subtle + soft -->
          <filter id="h-shadow" x="-10%" y="-10%" width="130%" height="140%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#000" flood-opacity="0.04"/>
            <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#000" flood-opacity="0.06"/>
          </filter>
          <!-- Glow for the central book -->
          <filter id="h-glow" x="-40%" y="-40%" width="180%" height="180%">
            <feGaussianBlur stdDeviation="10" result="blur"/>
            <feColorMatrix in="blur" type="matrix"
              values="0 0 0 0 0.29
                      0 0 0 0 0.69
                      0 0 0 0 0.31
                      0 0 0 0.35 0" result="colored"/>
            <feMerge>
              <feMergeNode in="colored"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
          <!-- Multi-stop brand gradient -->
          <linearGradient id="h-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#66BB6A"/>
            <stop offset="50%" stop-color="#4CAF50"/>
            <stop offset="100%" stop-color="#2E7D32"/>
          </linearGradient>
          <!-- Card surface gradient -->
          <linearGradient id="h-card" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#ffffff"/>
            <stop offset="100%" stop-color="#f9fdf9"/>
          </linearGradient>
          <!-- Flowing line gradient -->
          <linearGradient id="h-flow" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#4CAF50" stop-opacity="0"/>
            <stop offset="50%" stop-color="#66BB6A" stop-opacity="0.7"/>
            <stop offset="100%" stop-color="#4CAF50" stop-opacity="0"/>
          </linearGradient>
          <!-- Soft ambient glow -->
          <radialGradient id="h-ambient" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.08"/>
            <stop offset="50%" stop-color="#4CAF50" stop-opacity="0.02"/>
            <stop offset="100%" stop-color="#4CAF50" stop-opacity="0"/>
          </radialGradient>
          <!-- Dot grid pattern -->
          <pattern id="h-dots" width="28" height="28" patternUnits="userSpaceOnUse">
            <circle cx="14" cy="14" r="0.8" fill="#4CAF50" opacity="0.06"/>
          </pattern>
        </defs>

        <!-- Layer 0: Ambient background -->
        <rect x="0" y="0" width="480" height="290" fill="url(#h-dots)"/>
        <circle cx="240" cy="145" r="180" fill="url(#h-ambient)"/>

        <!-- Ambient floating accent circles -->
        <circle class="h-amb-c" cx="80" cy="60" r="4" fill="#81C784" opacity="0"/>
        <circle class="h-amb-c" cx="400" cy="220" r="3" fill="#81C784" opacity="0"/>

        <!-- Layer 1: Fragment cards with type icons -->

        <!-- Fragment 1: Book / article (top-left) -->
        <g class="h-frag h-f1">
          <rect x="20" y="22" width="76" height="52" rx="8" fill="url(#h-card)" stroke="#e8eee8" stroke-width="1" filter="url(#h-shadow)"/>
          <!-- Book icon -->
          <path d="M 28,34 L 28,48 C 28,48 33,46 38,48 L 38,34 C 33,32 28,34 28,34 Z" fill="#FFF3E0" stroke="#FFB74D" stroke-width="0.7"/>
          <path d="M 38,34 L 38,48 C 38,48 43,46 48,48 L 48,34 C 43,32 38,34 38,34 Z" fill="#FFF3E0" stroke="#FFB74D" stroke-width="0.7"/>
          <line x1="38" y1="34" x2="38" y2="48" stroke="#FFB74D" stroke-width="0.7"/>
          <!-- Text lines -->
          <rect x="52" y="35" width="34" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="52" y="41" width="28" height="2" rx="1" fill="#EEEEEE"/>
          <rect x="52" y="47" width="32" height="2" rx="1" fill="#EEEEEE"/>
          <text x="58" y="68" text-anchor="middle" font-size="8" fill="#AAA" font-weight="500">书籍</text>
        </g>

        <!-- Fragment 2: Web article (top-right) -->
        <g class="h-frag h-f2">
          <rect x="378" y="14" width="72" height="50" rx="8" fill="url(#h-card)" stroke="#e8eee8" stroke-width="1" filter="url(#h-shadow)"/>
          <!-- Browser window icon -->
          <rect x="390" y="26" width="14" height="10" rx="1.5" fill="#E3F2FD" stroke="#BBDEFB" stroke-width="0.6"/>
          <line x1="392" y1="29" x2="402" y2="29" stroke="#90CAF9" stroke-width="0.8"/>
          <line x1="392" y1="32" x2="399" y2="32" stroke="#BBDEFB" stroke-width="0.8"/>
          <!-- Text lines -->
          <rect x="410" y="27" width="30" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="410" y="32" width="24" height="2" rx="1" fill="#EEEEEE"/>
          <text x="414" y="58" text-anchor="middle" font-size="8" fill="#AAA" font-weight="500">网页文章</text>
        </g>

        <!-- Fragment 3: Markdown file (bottom-left) -->
        <g class="h-frag h-f3">
          <rect x="14" y="210" width="70" height="46" rx="8" fill="url(#h-card)" stroke="#e8eee8" stroke-width="1" filter="url(#h-shadow)"/>
          <!-- File icon -->
          <rect x="26" y="222" width="13" height="10" rx="1.5" fill="#FFF8E1" stroke="#FFE0B2" stroke-width="0.6"/>
          <text x="32.5" y="229" text-anchor="middle" font-size="6" fill="#FF8F00" font-weight="700">MD</text>
          <!-- Text lines -->
          <rect x="44" y="223" width="32" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="44" y="228" width="26" height="2" rx="1" fill="#EEEEEE"/>
          <text x="49" y="252" text-anchor="middle" font-size="8" fill="#AAA" font-weight="500">Markdown</text>
        </g>

        <!-- Fragment 4: Screenshot/image (bottom-right) -->
        <g class="h-frag h-f4">
          <rect x="383" y="204" width="76" height="50" rx="8" fill="url(#h-card)" stroke="#e8eee8" stroke-width="1" filter="url(#h-shadow)"/>
          <!-- Image icon -->
          <rect x="394" y="216" width="14" height="10" rx="1.5" fill="#F3E5F5" stroke="#E1BEE7" stroke-width="0.6"/>
          <circle cx="398" cy="220" r="1.2" fill="#CE93D8"/>
          <polygon points="394,226 399,222 404,226" fill="#E1BEE7"/>
          <!-- Text lines -->
          <rect x="413" y="217" width="36" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="413" y="222" width="28" height="2" rx="1" fill="#EEEEEE"/>
          <text x="421" y="248" text-anchor="middle" font-size="8" fill="#AAA" font-weight="500">截图/图片</text>
        </g>

        <!-- Fragment 5: Audio/podcast (top-center) -->
        <g class="h-frag h-f5">
          <rect x="178" y="6" width="84" height="44" rx="8" fill="url(#h-card)" stroke="#e8eee8" stroke-width="1" filter="url(#h-shadow)"/>
          <!-- Audio waveform icon -->
          <rect x="190" y="18" width="2" height="6" rx="1" fill="#CE93D8"/>
          <rect x="194" y="15" width="2" height="12" rx="1" fill="#AB47BC"/>
          <rect x="198" y="12" width="2" height="18" rx="1" fill="#9C27B0"/>
          <rect x="202" y="14" width="2" height="14" rx="1" fill="#AB47BC"/>
          <rect x="206" y="17" width="2" height="8" rx="1" fill="#CE93D8"/>
          <!-- Text lines -->
          <rect x="214" y="16" width="36" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="214" y="22" width="28" height="2" rx="1" fill="#EEEEEE"/>
          <text x="220" y="44" text-anchor="middle" font-size="8" fill="#AAA" font-weight="500">语音/播客</text>
        </g>

        <!-- Center Wiki book with glow -->
        <g class="h-book" filter="url(#h-glow)">
          <!-- Book pages with subtle gradient -->
          <rect x="148" y="90" width="88" height="118" rx="5" fill="url(#h-card)" stroke="#d8ddd8" stroke-width="1"/>
          <rect x="239" y="90" width="88" height="118" rx="5" fill="url(#h-card)" stroke="#d8ddd8" stroke-width="1"/>
          <!-- Spine -->
          <rect x="236" y="90" width="6" height="118" fill="#e8eee8"/>
          <!-- Left page: structured paragraph lines -->
          <rect x="160" y="106" width="58" height="2.5" rx="1" fill="#C8E6C9"/>
          <rect x="160" y="114" width="48" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="160" y="120" width="54" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="160" y="126" width="40" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="160" y="136" width="56" height="2.5" rx="1" fill="#C8E6C9"/>
          <rect x="160" y="144" width="44" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="160" y="150" width="50" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="160" y="156" width="36" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="160" y="166" width="52" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="160" y="172" width="42" height="2" rx="1" fill="#E8E8E8"/>
          <!-- Right page: structured paragraph lines -->
          <rect x="252" y="106" width="58" height="2.5" rx="1" fill="#C8E6C9"/>
          <rect x="252" y="114" width="46" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="252" y="120" width="52" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="252" y="126" width="38" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="252" y="136" width="56" height="2.5" rx="1" fill="#C8E6C9"/>
          <rect x="252" y="144" width="42" height="2" rx="1" fill="#E0E0E0"/>
          <rect x="252" y="150" width="50" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="252" y="156" width="36" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="252" y="166" width="48" height="2" rx="1" fill="#E8E8E8"/>
          <rect x="252" y="172" width="44" height="2" rx="1" fill="#E8E8E8"/>
          <!-- Wiki label -->
          <rect x="210" y="186" width="56" height="12" rx="6" fill="#E8F5E9"/>
          <text x="238" y="195" text-anchor="middle" font-size="8.5" fill="#2E7D32" font-weight="600">我的知识 Wiki</text>
        </g>

        <!-- Connecting lines with gradient stroke -->
        <g class="h-line h-l1">
          <line x1="58" y1="74" x2="192" y2="112" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="90" stroke-dashoffset="90" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l2">
          <line x1="414" y1="64" x2="282" y2="112" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="90" stroke-dashoffset="90" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l3">
          <line x1="49" y1="210" x2="192" y2="178" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="100" stroke-dashoffset="100" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l4">
          <line x1="421" y1="204" x2="282" y2="178" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="100" stroke-dashoffset="100" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l5">
          <line x1="220" y1="50" x2="238" y2="90" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="60" stroke-dashoffset="60" stroke-linecap="round"/>
        </g>

        <!-- Flowing particles along lines -->
        <circle class="h-particle h-p1" cx="0" cy="0" r="2" fill="#81C784" opacity="0"/>
        <circle class="h-particle h-p2" cx="0" cy="0" r="2" fill="#81C784" opacity="0"/>
        <circle class="h-particle h-p3" cx="0" cy="0" r="2" fill="#81C784" opacity="0"/>
      </svg>
    </SVGVisual>
  </div>
</section>

<style is:global>
  .hero { padding: var(--space-3xl) 0 var(--space-2xl); }
  .hero__brand { margin-bottom: var(--space-sm); }
  .hero__logo { height: 220px; width: auto; display: block; margin: 0 auto; }
  .hero__tagline { font-size: 20px; color: var(--color-text-secondary); font-weight: 500; margin-bottom: var(--space-xs); }
  .hero__subtitle { font-size: 17px; color: var(--color-text-tertiary); max-width: 440px; margin: 0 auto var(--space-lg); line-height: 1.7; }
  .hero__cta { margin-bottom: var(--space-xl); }

  /* Spring easing */
  :root { --spring: cubic-bezier(0.34, 1.56, 0.64, 1); }

  .h-frag, .h-book, .h-line, .h-amb-c, .h-particle { transform-box: fill-box; transform-origin: center center; }

  /* Ambient floating */
  .h-amb-c { opacity: 0; }
  .svg-visual.visible .h-amb-c:nth-of-type(1) {
    animation: h-float 5s ease-in-out infinite; animation-delay: 1s;
  }
  .svg-visual.visible .h-amb-c:nth-of-type(2) {
    animation: h-float 6s ease-in-out infinite; animation-delay: 2s;
  }
  @keyframes h-float {
    0%, 100% { opacity: 0.03; transform: translate(0, 0); }
    50%      { opacity: 0.12; transform: translate(8px, -6px); }
  }

  /* Fragment stagger-in with spring */
  .h-frag { opacity: 0; transform: translateY(-14px); }
  .svg-visual.visible .h-f1 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0s; }
  .svg-visual.visible .h-f2 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.1s; }
  .svg-visual.visible .h-f3 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.2s; }
  .svg-visual.visible .h-f4 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.3s; }
  .svg-visual.visible .h-f5 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.4s; }
  @keyframes h-in {
    0%   { opacity: 0; transform: translateY(-14px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* Book spring-in */
  .h-book { opacity: 0; transform: scale(0.8); }
  .svg-visual.visible .h-book {
    animation: h-book-in 0.55s var(--spring) forwards;
    animation-delay: 0.6s;
  }
  @keyframes h-book-in {
    0%   { opacity: 0; transform: scale(0.8); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* Lines draw */
  .h-line { opacity: 0; }
  .svg-visual.visible .h-l1 { animation: h-draw 0.4s ease-out forwards; animation-delay: 0.95s; }
  .svg-visual.visible .h-l2 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.05s; }
  .svg-visual.visible .h-l3 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.15s; }
  .svg-visual.visible .h-l4 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.25s; }
  .svg-visual.visible .h-l5 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.35s; }
  @keyframes h-draw {
    0%   { opacity: 1; stroke-dashoffset: inherit; }
    100% { stroke-dashoffset: 0; }
  }

  /* Flowing particles */
  .h-particle { opacity: 0; }
  .svg-visual.visible .h-p1 {
    animation: h-flow-1 3s ease-in-out infinite; animation-delay: 1.5s;
  }
  .svg-visual.visible .h-p2 {
    animation: h-flow-2 3.5s ease-in-out infinite; animation-delay: 2s;
  }
  .svg-visual.visible .h-p3 {
    animation: h-flow-3 4s ease-in-out infinite; animation-delay: 2.5s;
  }
  @keyframes h-flow-1 {
    0%   { opacity: 0; transform: translate(58px, 74px); }
    20%  { opacity: 0.7; }
    80%  { opacity: 0.7; }
    100% { opacity: 0; transform: translate(192px, 112px); }
  }
  @keyframes h-flow-2 {
    0%   { opacity: 0; transform: translate(414px, 64px); }
    20%  { opacity: 0.7; }
    80%  { opacity: 0.7; }
    100% { opacity: 0; transform: translate(282px, 112px); }
  }
  @keyframes h-flow-3 {
    0%   { opacity: 0; transform: translate(49px, 210px); }
    20%  { opacity: 0.7; }
    80%  { opacity: 0.7; }
    100% { opacity: 0; transform: translate(192px, 178px); }
  }
</style>
