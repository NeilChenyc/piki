---
import Button from '../components/Button.astro';
import SVGVisual from '../components/SVGVisual.astro';
---
<section class="hero">
  <div class="container text-center">
    <h1 class="hero__title">你的 LLM Wiki</h1>
    <p class="hero__subtitle">
      AI 维护你的个人知识库。你只管输入和提问。
    </p>
    <p class="hero__meta">本地 Markdown · AI 驱动 · 完全属于你</p>
    <div class="hero__cta">
      <Button href="#download">免费下载 macOS 版</Button>
    </div>
    <SVGVisual alt="碎片信息编译为结构化 Wiki">
      <svg viewBox="0 0 480 290" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Soft drop shadow for cards -->
          <filter id="h-shadow" x="-10%" y="-10%" width="130%" height="140%">
            <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="#000" flood-opacity="0.06"/>
          </filter>
          <!-- Glow for the central book -->
          <filter id="h-glow" x="-30%" y="-30%" width="160%" height="160%">
            <feGaussianBlur stdDeviation="8" result="blur"/>
            <feComposite in="SourceGraphic" in2="blur" operator="over"/>
          </filter>
          <!-- Brand green gradient -->
          <linearGradient id="h-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="var(--color-accent, #4CAF50)"/>
            <stop offset="100%" stop-color="#2E7D32"/>
          </linearGradient>
          <!-- Soft ambient glow -->
          <radialGradient id="h-ambient" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.07"/>
            <stop offset="60%" stop-color="#4CAF50" stop-opacity="0.02"/>
            <stop offset="100%" stop-color="#4CAF50" stop-opacity="0"/>
          </radialGradient>
          <!-- Dot grid pattern -->
          <pattern id="h-dots" width="28" height="28" patternUnits="userSpaceOnUse">
            <circle cx="14" cy="14" r="0.8" fill="#4CAF50" opacity="0.07"/>
          </pattern>
        </defs>

        <!-- Layer 0: Ambient background -->
        <rect x="0" y="0" width="480" height="290" fill="url(#h-dots)"/>
        <circle cx="240" cy="145" r="180" fill="url(#h-ambient)"/>

        <!-- Ambient floating accent circles -->
        <circle class="h-amb-c" cx="80" cy="60" r="5" fill="#4CAF50" opacity="0.05"/>
        <circle class="h-amb-c" cx="400" cy="220" r="4" fill="#4CAF50" opacity="0.04"/>

        <!-- Layer 1: Main illustration -->
        <!-- Fragment 1 -->
        <g class="h-frag h-f1">
          <rect x="20" y="22" width="76" height="52" rx="7" fill="white" stroke="#e8e8e8" stroke-width="1" filter="url(#h-shadow)"/>
          <rect x="33" y="36" width="48" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="33" y="44" width="36" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="33" y="52" width="42" height="2.5" rx="1" fill="#e0e0e0"/>
          <text x="58" y="68" text-anchor="middle" font-size="9" fill="#999" font-weight="500">架构设计笔记</text>
        </g>

        <!-- Fragment 2 -->
        <g class="h-frag h-f2">
          <rect x="378" y="14" width="72" height="50" rx="7" fill="white" stroke="#e8e8e8" stroke-width="1" filter="url(#h-shadow)"/>
          <rect x="391" y="28" width="42" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="391" y="36" width="30" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="391" y="44" width="36" height="2.5" rx="1" fill="#e0e0e0"/>
          <text x="414" y="58" text-anchor="middle" font-size="9" fill="#999" font-weight="500">商业案例分析</text>
        </g>

        <!-- Fragment 3 -->
        <g class="h-frag h-f3">
          <rect x="14" y="210" width="70" height="46" rx="7" fill="white" stroke="#e8e8e8" stroke-width="1" filter="url(#h-shadow)"/>
          <rect x="27" y="224" width="40" height="2" rx="1" fill="#e0e0e0"/>
          <rect x="27" y="232" width="48" height="2" rx="1" fill="#e0e0e0"/>
          <rect x="27" y="240" width="30" height="2" rx="1" fill="#e0e0e0"/>
          <text x="49" y="252" text-anchor="middle" font-size="9" fill="#999" font-weight="500">历史研究摘录</text>
        </g>

        <!-- Fragment 4 -->
        <g class="h-frag h-f4">
          <rect x="383" y="204" width="76" height="50" rx="7" fill="white" stroke="#e8e8e8" stroke-width="1" filter="url(#h-shadow)"/>
          <rect x="396" y="218" width="44" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="396" y="226" width="52" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="396" y="234" width="36" height="2.5" rx="1" fill="#e0e0e0"/>
          <text x="421" y="248" text-anchor="middle" font-size="9" fill="#999" font-weight="500">设计原则汇总</text>
        </g>

        <!-- Fragment 5 -->
        <g class="h-frag h-f5">
          <rect x="178" y="6" width="84" height="44" rx="7" fill="white" stroke="#e8e8e8" stroke-width="1" filter="url(#h-shadow)"/>
          <rect x="191" y="18" width="26" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="223" y="18" width="28" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="191" y="28" width="22" height="2.5" rx="1" fill="#e0e0e0"/>
          <rect x="219" y="28" width="32" height="2.5" rx="1" fill="#e0e0e0"/>
          <text x="220" y="44" text-anchor="middle" font-size="9" fill="#999" font-weight="500">读书笔记</text>
        </g>

        <!-- Center Wiki book with glow -->
        <g class="h-book" filter="url(#h-glow)">
          <rect x="148" y="90" width="88" height="118" rx="4" fill="white" stroke="#d0d0d0" stroke-width="1"/>
          <rect x="239" y="90" width="88" height="118" rx="4" fill="white" stroke="#d0d0d0" stroke-width="1"/>
          <rect x="236" y="90" width="6" height="118" fill="#e8e8e8"/>
          <!-- Left page -->
          <rect x="163" y="108" width="55" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="163" y="118" width="45" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="163" y="128" width="52" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="163" y="138" width="40" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="163" y="148" width="50" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="163" y="158" width="36" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="163" y="168" width="48" height="2" rx="1" fill="#e8e8e8"/>
          <!-- Right page -->
          <rect x="254" y="108" width="55" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="254" y="118" width="42" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="254" y="128" width="50" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="254" y="138" width="32" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="254" y="148" width="46" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="254" y="158" width="38" height="2" rx="1" fill="#e8e8e8"/>
          <rect x="254" y="168" width="52" height="2" rx="1" fill="#e8e8e8"/>
          <text x="238" y="222" text-anchor="middle" font-size="10" fill="#999">我的知识 Wiki</text>
        </g>

        <!-- Connecting lines with gradient stroke -->
        <g class="h-line h-l1">
          <line x1="58" y1="74" x2="192" y2="112" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="90" stroke-dashoffset="90" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l2">
          <line x1="414" y1="64" x2="282" y2="112" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="90" stroke-dashoffset="90" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l3">
          <line x1="49" y1="210" x2="192" y2="178" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="100" stroke-dashoffset="100" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l4">
          <line x1="421" y1="204" x2="282" y2="178" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="100" stroke-dashoffset="100" stroke-linecap="round"/>
        </g>
        <g class="h-line h-l5">
          <line x1="220" y1="50" x2="238" y2="90" stroke="url(#h-grad)" stroke-width="1.5" stroke-dasharray="60" stroke-dashoffset="60" stroke-linecap="round"/>
        </g>
      </svg>
    </SVGVisual>
  </div>
</section>

<style is:global>
  .hero { padding: var(--space-3xl) 0 var(--space-2xl); }
  .hero__title { margin-bottom: var(--space-md); }
  .hero__subtitle { font-size: 19px; color: var(--color-text-secondary); max-width: 480px; margin: 0 auto var(--space-sm); line-height: 1.7; }
  .hero__meta { font-size: 14px; color: var(--color-text-tertiary); letter-spacing: 0.03em; margin-bottom: var(--space-lg); }
  .hero__cta { margin-bottom: var(--space-xl); }

  /* Spring easing */
  :root { --spring: cubic-bezier(0.34, 1.56, 0.64, 1); }

  .h-frag, .h-book, .h-line, .h-amb-c { transform-box: fill-box; transform-origin: center center; }

  /* Ambient floating */
  .h-amb-c { opacity: 0; }
  .svg-visual.visible .h-amb-c:nth-of-type(1) {
    animation: h-float 5s ease-in-out infinite; animation-delay: 1s;
  }
  .svg-visual.visible .h-amb-c:nth-of-type(2) {
    animation: h-float 6s ease-in-out infinite; animation-delay: 2s;
  }
  @keyframes h-float {
    0%, 100% { opacity: 0.03; transform: translate(0, 0); }
    50%      { opacity: 0.1; transform: translate(8px, -6px); }
  }

  /* Fragment stagger-in with spring */
  .h-frag { opacity: 0; transform: translateY(-14px); }
  .svg-visual.visible .h-f1 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0s; }
  .svg-visual.visible .h-f2 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.1s; }
  .svg-visual.visible .h-f3 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.2s; }
  .svg-visual.visible .h-f4 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.3s; }
  .svg-visual.visible .h-f5 { animation: h-in 0.5s var(--spring) forwards; animation-delay: 0.4s; }
  @keyframes h-in {
    0%   { opacity: 0; transform: translateY(-14px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* Book spring-in */
  .h-book { opacity: 0; transform: scale(0.8); }
  .svg-visual.visible .h-book {
    animation: h-book-in 0.55s var(--spring) forwards;
    animation-delay: 0.6s;
  }
  @keyframes h-book-in {
    0%   { opacity: 0; transform: scale(0.8); }
    100% { opacity: 1; transform: scale(1); }
  }

  /* Lines draw */
  .h-line { opacity: 0; }
  .svg-visual.visible .h-l1 { animation: h-draw 0.4s ease-out forwards; animation-delay: 0.95s; }
  .svg-visual.visible .h-l2 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.05s; }
  .svg-visual.visible .h-l3 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.15s; }
  .svg-visual.visible .h-l4 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.25s; }
  .svg-visual.visible .h-l5 { animation: h-draw 0.4s ease-out forwards; animation-delay: 1.35s; }
  @keyframes h-draw {
    0%   { opacity: 1; stroke-dashoffset: inherit; }
    100% { stroke-dashoffset: 0; }
  }
</style>
