---
import SVGVisual from '../components/SVGVisual.astro';
---
<section class="section section--surface" id="unified-entry">
  <div class="container grid-2">
    <div class="feature-text fade-in">
      <h2>一个入口，说完就等结果</h2>
      <p class="text-secondary">不区分查询和编辑。说你要什么，Agent 自己判断执行。</p>
      <blockquote class="feature__quote">"帮我把最近读的几本思维方法论的书，提取出可复用的框架和模型。"</blockquote>
      <p class="text-secondary">你也可以直接拖入文件，Agent 自动识别内容类型并归入合适位置。</p>
    </div>
    <SVGVisual alt="一句话触发 Agent 多步处理">
      <svg viewBox="0 0 480 260" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="f1-shadow" x="-10%" y="-10%" width="130%" height="130%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#000" flood-opacity="0.04"/>
            <feDropShadow dx="0" dy="3" stdDeviation="6" flood-color="#000" flood-opacity="0.05"/>
          </filter>
          <filter id="f1-glow" x="-30%" y="-30%" width="160%" height="160%">
            <feGaussianBlur stdDeviation="6" result="blur"/>
            <feColorMatrix in="blur" type="matrix"
              values="0 0 0 0 0.29
                      0 0 0 0 0.69
                      0 0 0 0 0.31
                      0 0 0 0.25 0" result="colored"/>
            <feMerge>
              <feMergeNode in="colored"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
          <filter id="f1-hub-glow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="8" result="blur"/>
            <feColorMatrix in="blur" type="matrix"
              values="0 0 0 0 0.29
                      0 0 0 0 0.69
                      0 0 0 0 0.31
                      0 0 0 0.22 0" result="colored"/>
            <feMerge>
              <feMergeNode in="colored"/>
              <feMergeNode in="SourceGraphic"/>
            </feMerge>
          </filter>
          <linearGradient id="f1-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#66BB6A"/>
            <stop offset="100%" stop-color="#2E7D32"/>
          </linearGradient>
          <linearGradient id="f1-grad-search" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#42A5F5"/>
            <stop offset="100%" stop-color="#1E88E5"/>
          </linearGradient>
          <linearGradient id="f1-grad-extract" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#66BB6A"/>
            <stop offset="100%" stop-color="#2E7D32"/>
          </linearGradient>
          <linearGradient id="f1-grad-link" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#AB47BC"/>
            <stop offset="100%" stop-color="#7B1FA2"/>
          </linearGradient>
          <linearGradient id="f1-grad-index" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#FFA726"/>
            <stop offset="100%" stop-color="#F57C00"/>
          </linearGradient>
          <linearGradient id="f1-card" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#ffffff"/>
            <stop offset="100%" stop-color="#fafafa"/>
          </linearGradient>
          <radialGradient id="f1-ambient" cx="50%" cy="30%" r="55%">
            <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.05"/>
            <stop offset="100%" stop-color="#4CAF50" stop-opacity="0"/>
          </radialGradient>
          <pattern id="f1-dots" width="26" height="26" patternUnits="userSpaceOnUse">
            <circle cx="13" cy="13" r="0.7" fill="#4CAF50" opacity="0.04"/>
          </pattern>
        </defs>

        <rect width="480" height="260" fill="url(#f1-dots)"/>
        <circle cx="240" cy="90" r="160" fill="url(#f1-ambient)"/>

        <!-- Input bubble -->
        <g class="f1-bubble" filter="url(#f1-glow)">
          <rect x="100" y="14" width="280" height="42" rx="14" fill="#E8F5E9" stroke="#4CAF50" stroke-width="1.5"/>
          <text x="240" y="40" text-anchor="middle" font-size="12" fill="#2E7D32" font-weight="500">提取读书笔记中的方法论框架</text>
          <rect class="f1-cursor" x="340" y="30" width="2" height="14" rx="1" fill="#4CAF50"/>
          <polygon points="228,56 240,70 252,56" fill="#E8F5E9" stroke="#4CAF50" stroke-width="1.5"/>
        </g>

        <!-- Agent core -->
        <g class="f1-agent" filter="url(#f1-hub-glow)">
          <circle cx="240" cy="110" r="26" fill="url(#f1-card)" stroke="url(#f1-grad)" stroke-width="2"/>
          <text x="240" y="107" text-anchor="middle" font-size="9" fill="#2E7D32" font-weight="600">PIKI</text>
          <text x="240" y="118" text-anchor="middle" font-size="7" fill="#4CAF50">AGENT</text>
          <!-- Rotating ring -->
          <circle class="f1-agent-ring" cx="240" cy="110" r="32" fill="none" stroke="#4CAF50" stroke-width="1" stroke-dasharray="6,4" opacity="0.25"/>
        </g>

        <!-- Connector lines from agent to steps -->
        <line class="f1-conn f1-c1" x1="218" y1="132" x2="100" y2="168" stroke="url(#f1-grad-search)" stroke-width="1.6" stroke-linecap="round"/>
        <line class="f1-conn f1-c2" x1="232" y1="136" x2="190" y2="168" stroke="url(#f1-grad-extract)" stroke-width="1.6" stroke-linecap="round"/>
        <line class="f1-conn f1-c3" x1="248" y1="136" x2="290" y2="168" stroke="url(#f1-grad-link)" stroke-width="1.6" stroke-linecap="round"/>
        <line class="f1-conn f1-c4" x1="262" y1="132" x2="380" y2="168" stroke="url(#f1-grad-index)" stroke-width="1.6" stroke-linecap="round"/>

        <!-- Step 1: Search -->
        <g class="f1-step f1-s1">
          <rect x="46" y="168" width="88" height="58" rx="10" fill="url(#f1-card)" stroke="#e8e8e8" stroke-width="1" filter="url(#f1-shadow)"/>
          <circle cx="70" cy="188" r="9" fill="#E3F2FD" stroke="url(#f1-grad-search)" stroke-width="1.3"/>
          <circle cx="69" cy="187" r="2.5" fill="none" stroke="#1E88E5" stroke-width="1"/>
          <line x1="71" y1="189" x2="73" y2="191" stroke="#1E88E5" stroke-width="1" stroke-linecap="round"/>
          <text x="90" y="193" text-anchor="middle" font-size="10" fill="#333" font-weight="500">搜索</text>
          <text x="90" y="213" text-anchor="middle" font-size="8.5" fill="#999">匹配已有笔记</text>
        </g>

        <!-- Step 2: Extract -->
        <g class="f1-step f1-s2">
          <rect x="136" y="168" width="88" height="58" rx="10" fill="url(#f1-card)" stroke="#e8e8e8" stroke-width="1" filter="url(#f1-shadow)"/>
          <circle cx="160" cy="188" r="9" fill="#E8F5E9" stroke="url(#f1-grad-extract)" stroke-width="1.3"/>
          <path d="M 157,190 L 160,185 L 163,190 M 160,185 L 160,192" fill="none" stroke="#2E7D32" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="180" y="193" text-anchor="middle" font-size="10" fill="#333" font-weight="500">提取</text>
          <text x="180" y="213" text-anchor="middle" font-size="8.5" fill="#999">写入 concepts/</text>
        </g>

        <!-- Step 3: Link -->
        <g class="f1-step f1-s3">
          <rect x="246" y="168" width="88" height="58" rx="10" fill="url(#f1-card)" stroke="#e8e8e8" stroke-width="1" filter="url(#f1-shadow)"/>
          <circle cx="270" cy="188" r="9" fill="#F3E5F5" stroke="url(#f1-grad-link)" stroke-width="1.3"/>
          <path d="M 266,188 L 268,188 M 272,188 L 274,188" stroke="#7B1FA2" stroke-width="1.2" stroke-linecap="round"/>
          <circle cx="267" cy="188" r="1.5" fill="none" stroke="#7B1FA2" stroke-width="0.9"/>
          <circle cx="273" cy="188" r="1.5" fill="none" stroke="#7B1FA2" stroke-width="0.9"/>
          <text x="290" y="193" text-anchor="middle" font-size="10" fill="#333" font-weight="500">关联</text>
          <text x="290" y="213" text-anchor="middle" font-size="8.5" fill="#999">建立双向链接</text>
        </g>

        <!-- Step 4: Index -->
        <g class="f1-step f1-s4">
          <rect x="356" y="168" width="88" height="58" rx="10" fill="url(#f1-card)" stroke="#e8e8e8" stroke-width="1" filter="url(#f1-shadow)"/>
          <circle cx="380" cy="188" r="9" fill="#FFF3E0" stroke="url(#f1-grad-index)" stroke-width="1.3"/>
          <line x1="376" y1="185" x2="384" y2="185" stroke="#F57C00" stroke-width="1" stroke-linecap="round"/>
          <line x1="376" y1="188" x2="382" y2="188" stroke="#F57C00" stroke-width="1" stroke-linecap="round"/>
          <line x1="376" y1="191" x2="384" y2="191" stroke="#F57C00" stroke-width="1" stroke-linecap="round"/>
          <text x="400" y="193" text-anchor="middle" font-size="10" fill="#333" font-weight="500">索引</text>
          <text x="400" y="213" text-anchor="middle" font-size="8.5" fill="#999">维护 Wiki 结构</text>
        </g>
      </svg>
    </SVGVisual>
  </div>
</section>

<style is:global>
  .feature-text h2 { margin-bottom: var(--space-md); }
  .feature-text p { font-size: 17px; line-height: 1.7; margin-bottom: var(--space-md); }
  .feature__quote { margin: var(--space-md) 0; padding: var(--space-sm) var(--space-md); border-left: 3px solid var(--color-accent); background: var(--color-accent-light); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; font-size: 15px; color: var(--color-accent-dark); font-style: italic; }

  :root { --spring: cubic-bezier(0.34, 1.56, 0.64, 1); }

  .f1-bubble, .f1-agent, .f1-step, .f1-conn { transform-box: fill-box; transform-origin: center center; }

  .f1-bubble { opacity: 0; transform: translateY(-12px); }
  .svg-visual.visible .f1-bubble { animation: f1-up 0.5s var(--spring) forwards; animation-delay: 0.1s; }
  @keyframes f1-up { 0% { opacity: 0; transform: translateY(-12px); } 100% { opacity: 1; transform: translateY(0); } }

  .f1-cursor { opacity: 1; }
  .svg-visual.visible .f1-cursor { animation: f1-blink 1s step-end infinite; animation-delay: 0.6s; }
  @keyframes f1-blink { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }

  .f1-agent { opacity: 0; transform: scale(0.8); }
  .svg-visual.visible .f1-agent { animation: f1-pop 0.5s var(--spring) forwards; animation-delay: 0.45s; }
  @keyframes f1-pop { 0% { opacity: 0; transform: scale(0.8); } 100% { opacity: 1; transform: scale(1); } }

  .f1-agent-ring { transform-box: fill-box; transform-origin: center center; }
  .svg-visual.visible .f1-agent-ring { animation: f1-rotate 12s linear infinite; animation-delay: 0.8s; }
  @keyframes f1-rotate { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

  .f1-conn { opacity: 0; stroke-dasharray: 90; stroke-dashoffset: 90; }
  .svg-visual.visible .f1-c1 { animation: f1-draw 0.35s ease-out forwards; animation-delay: 0.8s; }
  .svg-visual.visible .f1-c2 { animation: f1-draw 0.35s ease-out forwards; animation-delay: 0.9s; }
  .svg-visual.visible .f1-c3 { animation: f1-draw 0.35s ease-out forwards; animation-delay: 1.0s; }
  .svg-visual.visible .f1-c4 { animation: f1-draw 0.35s ease-out forwards; animation-delay: 1.1s; }
  @keyframes f1-draw { to { stroke-dashoffset: 0; opacity: 1; } }

  .f1-step { opacity: 0; transform: translateY(10px); }
  .svg-visual.visible .f1-s1 { animation: f1-step-in 0.45s var(--spring) forwards; animation-delay: 1.0s; }
  .svg-visual.visible .f1-s2 { animation: f1-step-in 0.45s var(--spring) forwards; animation-delay: 1.15s; }
  .svg-visual.visible .f1-s3 { animation: f1-step-in 0.45s var(--spring) forwards; animation-delay: 1.3s; }
  .svg-visual.visible .f1-s4 { animation: f1-step-in 0.45s var(--spring) forwards; animation-delay: 1.45s; }
  @keyframes f1-step-in { 0% { opacity: 0; transform: translateY(10px); } 100% { opacity: 1; transform: translateY(0); } }

  @media (max-width: 900px) { .grid-2 :global(.svg-visual) { order: -1; } }
</style>
