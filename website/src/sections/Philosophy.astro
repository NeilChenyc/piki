---
import SVGVisual from '../components/SVGVisual.astro';
---
<section class="section section--surface" id="philosophy">
  <div class="container grid-2">
    <div class="phil-text fade-in">
      <h2>知识库不该由你来维护</h2>
      <p class="text-secondary">传统笔记系统靠人维护：命名、分类、格式、链接、索引——维护成本最终超过使用价值。</p>
      <p class="text-secondary">Piki 靠 AI 维护。你只负责输入，AI 负责让一切保持有序。</p>
      <div class="phil__points">
        <div class="phil__point"><span class="phil__dot"></span><span><strong>持久有序</strong> — AI 以 LLM Wiki 格式持续维护，不随时间退化</span></div>
        <div class="phil__point"><span class="phil__dot"></span><span><strong>由点成面</strong> — 碎片知识被 AI 自动发现关联、建立链接、聚合为网络</span></div>
      </div>
    </div>
    <SVGVisual alt="传统笔记 vs LLM Wiki 对比">
      <svg viewBox="0 0 480 300" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="p-card-shadow" x="-10%" y="-10%" width="130%" height="140%">
            <feDropShadow dx="0" dy="1" stdDeviation="2" flood-color="#000" flood-opacity="0.05"/>
            <feDropShadow dx="0" dy="3" stdDeviation="6" flood-color="#000" flood-opacity="0.04"/>
          </filter>
          <filter id="p-node-shadow" x="-10%" y="-10%" width="130%" height="130%">
            <feDropShadow dx="0" dy="2" stdDeviation="6" flood-color="#4CAF50" flood-opacity="0.12"/>
          </filter>
          <linearGradient id="p-accent" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#66BB6A"/>
            <stop offset="100%" stop-color="#2E7D32"/>
          </linearGradient>
          <linearGradient id="p-card-warm" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#FFFDE7"/>
            <stop offset="100%" stop-color="#FFF9C4"/>
          </linearGradient>
          <linearGradient id="p-card-cool" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#E3F2FD"/>
            <stop offset="100%" stop-color="#BBDEFB"/>
          </linearGradient>
          <linearGradient id="p-card-green" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#E8F5E9"/>
            <stop offset="100%" stop-color="#C8E6C9"/>
          </linearGradient>
          <linearGradient id="p-card-white" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#ffffff"/>
            <stop offset="100%" stop-color="#fafafa"/>
          </linearGradient>
          <radialGradient id="p-glow-l" cx="35%" cy="50%" r="45%">
            <stop offset="0%" stop-color="#FFF9C4" stop-opacity="0.12"/>
            <stop offset="100%" stop-color="#FFF9C4" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="p-glow-r" cx="65%" cy="50%" r="45%">
            <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.06"/>
            <stop offset="100%" stop-color="#4CAF50" stop-opacity="0"/>
          </radialGradient>
          <pattern id="p-dots" width="24" height="24" patternUnits="userSpaceOnUse">
            <circle cx="12" cy="12" r="0.7" fill="#4CAF50" opacity="0.04"/>
          </pattern>
        </defs>

        <!-- Background -->
        <rect width="480" height="300" fill="url(#p-dots)"/>
        <circle cx="120" cy="150" r="160" fill="url(#p-glow-l)"/>
        <circle cx="360" cy="150" r="160" fill="url(#p-glow-r)"/>
        <line x1="240" y1="24" x2="240" y2="280" stroke="#e8e8e8" stroke-width="1" stroke-dasharray="6,4"/>

        <!-- LEFT: Traditional — chaotic cards -->
        <text x="120" y="22" text-anchor="middle" font-size="10" fill="#bbb" font-weight="500">传统笔记 — 你手动维护</text>

        <g class="p-s p-s1" filter="url(#p-card-shadow)">
          <rect x="30" y="42" width="86" height="50" rx="5" fill="url(#p-card-warm)" stroke="#E0D89C" stroke-width="0.8"/>
          <rect x="40" y="54" width="50" height="2" rx="1" fill="#D4C88C"/>
          <rect x="40" y="60" width="38" height="2" rx="1" fill="#DDD0A0"/>
          <rect x="40" y="66" width="44" height="2" rx="1" fill="#DDD0A0"/>
          <text x="73" y="84" text-anchor="middle" font-size="8" fill="#b8a868">分布式系统笔记</text>
        </g>
        <g class="p-s p-s2" filter="url(#p-card-shadow)">
          <rect x="128" y="36" width="72" height="44" rx="5" fill="url(#p-card-warm)" stroke="#E0D89C" stroke-width="0.8"/>
          <rect x="136" y="47" width="42" height="2" rx="1" fill="#D4C88C"/>
          <rect x="136" y="53" width="30" height="2" rx="1" fill="#DDD0A0"/>
          <text x="164" y="73" text-anchor="middle" font-size="8" fill="#b8a868">商业模式画布</text>
        </g>
        <g class="p-s p-s3" filter="url(#p-card-shadow)">
          <rect x="26" y="114" width="74" height="44" rx="5" fill="url(#p-card-cool)" stroke="#90CAF9" stroke-width="0.8"/>
          <rect x="34" y="125" width="44" height="2" rx="1" fill="#82B6E8"/>
          <rect x="34" y="131" width="36" height="2" rx="1" fill="#A8CCEF"/>
          <rect x="34" y="137" width="40" height="2" rx="1" fill="#A8CCEF"/>
          <text x="63" y="152" text-anchor="middle" font-size="8" fill="#6ba3d8">罗马帝国研究</text>
        </g>
        <g class="p-s p-s4" filter="url(#p-card-shadow)">
          <rect x="112" y="108" width="72" height="48" rx="5" fill="url(#p-card-warm)" stroke="#E0D89C" stroke-width="0.8"/>
          <rect x="120" y="120" width="40" height="2" rx="1" fill="#D4C88C"/>
          <rect x="120" y="126" width="34" height="2" rx="1" fill="#DDD0A0"/>
          <text x="148" y="148" text-anchor="middle" font-size="8" fill="#b8a868">设计原则</text>
        </g>
        <g class="p-s p-s5" filter="url(#p-card-shadow)">
          <rect x="148" y="168" width="68" height="40" rx="5" fill="url(#p-card-green)" stroke="#A5D6A7" stroke-width="0.8"/>
          <rect x="155" y="180" width="38" height="2" rx="1" fill="#81C784"/>
          <text x="182" y="200" text-anchor="middle" font-size="8" fill="#5a9c5d">投资方法论</text>
        </g>
        <g class="p-s p-s6" filter="url(#p-card-shadow)">
          <rect x="30" y="180" width="76" height="46" rx="5" fill="url(#p-card-warm)" stroke="#E0D89C" stroke-width="0.8"/>
          <rect x="38" y="192" width="44" height="2" rx="1" fill="#D4C88C"/>
          <rect x="38" y="198" width="32" height="2" rx="1" fill="#DDD0A0"/>
          <text x="68" y="220" text-anchor="middle" font-size="8" fill="#b8a868">叙事结构分析</text>
        </g>

        <!-- Broken links -->
        <g class="p-s p-s7" opacity="0.4">
          <line x1="73" y1="92" x2="63" y2="114" stroke="#ccc" stroke-width="0.8" stroke-dasharray="3,3"/>
          <line x1="164" y1="80" x2="148" y2="108" stroke="#ccc" stroke-width="0.8" stroke-dasharray="3,3"/>
        </g>

        <g class="p-bad"><text x="120" y="278" text-anchor="middle" font-size="9" fill="#EF5350" font-weight="500">✕ 分散 · 断裂 · 无法检索</text></g>

        <!-- RIGHT: LLM Wiki — one concrete concept with full knowledge system -->
        <text x="360" y="22" text-anchor="middle" font-size="10" fill="#4CAF50" font-weight="500">LLM Wiki — AI 持续维护</text>

        <!-- Input raw/ folder -->
        <g class="p-w p-w-raw" filter="url(#p-card-shadow)">
          <path d="M 275,75 L 275,60 C 275,56 278,53 282,53 L 301,53 C 304,53 306,55 306,58 L 308,58 L 308,75 Z" fill="url(#p-card-warm)" stroke="#E0D89C" stroke-width="0.8"/>
          <text x="291" y="69" text-anchor="middle" font-size="8" fill="#b8a868">raw/</text>
        </g>

        <!-- Inbox batch -->
        <g class="p-w p-w-inbox" filter="url(#p-card-shadow)">
          <rect x="270" y="95" width="38" height="18" rx="9" fill="#FFF9C4" stroke="#E0D89C" stroke-width="0.8"/>
          <text x="289" y="107" text-anchor="middle" font-size="7.5" fill="#b8a868">inbox</text>
        </g>

        <!-- Main concept card -->
        <g class="p-w p-w-main" filter="url(#p-node-shadow)">
          <rect x="310" y="120" width="100" height="46" rx="10" fill="url(#p-card-white)" stroke="url(#p-accent)" stroke-width="2"/>
          <circle cx="328" cy="143" r="6" fill="url(#p-accent)"/>
          <text x="360" y="138" text-anchor="middle" font-size="10" fill="#333" font-weight="600">思维模型</text>
          <text x="360" y="156" text-anchor="middle" font-size="8" fill="#999">wiki/concepts/</text>
        </g>

        <!-- Wiki sub-folders: entities / synthesis -->
        <g class="p-w p-w-entities" filter="url(#p-card-shadow)">
          <rect x="355" y="80" width="70" height="28" rx="6" fill="url(#p-card-white)" stroke="#C8E6C9" stroke-width="1"/>
          <text x="390" y="92" text-anchor="middle" font-size="8" fill="#5a9c5d" font-weight="500">entities/</text>
          <text x="390" y="102" text-anchor="middle" font-size="7" fill="#999">查理·芒格</text>
        </g>
        <g class="p-w p-w-synthesis" filter="url(#p-card-shadow)">
          <rect x="355" y="178" width="70" height="28" rx="6" fill="url(#p-card-white)" stroke="#C8E6C9" stroke-width="1"/>
          <text x="390" y="190" text-anchor="middle" font-size="8" fill="#5a9c5d" font-weight="500">synthesis/</text>
          <text x="390" y="200" text-anchor="middle" font-size="7" fill="#999">反脆弱总结</text>
        </g>

        <!-- Related knowledge nodes (grey, small) -->
        <g class="p-w p-w-rel1" filter="url(#p-card-shadow)">
          <rect x="435" y="95" width="40" height="20" rx="4" fill="#f5f5f5" stroke="#ddd" stroke-width="0.8"/>
          <text x="455" y="108" text-anchor="middle" font-size="7" fill="#aaa">设计原则</text>
        </g>
        <g class="p-w p-w-rel2" filter="url(#p-card-shadow)">
          <rect x="435" y="155" width="40" height="20" rx="4" fill="#f5f5f5" stroke="#ddd" stroke-width="0.8"/>
          <text x="455" y="168" text-anchor="middle" font-size="7" fill="#aaa">商业模式</text>
        </g>
        <g class="p-w p-w-rel3" filter="url(#p-card-shadow)">
          <rect x="435" y="215" width="40" height="20" rx="4" fill="#f5f5f5" stroke="#ddd" stroke-width="0.8"/>
          <text x="455" y="228" text-anchor="middle" font-size="7" fill="#aaa">罗马帝国</text>
        </g>

        <!-- Edges: raw → inbox → main concept -->
        <g class="p-e p-e-raw-inbox"><line x1="289" y1="75" x2="289" y2="95" stroke="#E0D89C" stroke-width="1" stroke-dasharray="20" stroke-dashoffset="20" stroke-linecap="round"/></g>
        <g class="p-e p-e-inbox-main"><line x1="292" y1="113" x2="322" y2="136" stroke="#E0D89C" stroke-width="1" stroke-dasharray="30" stroke-dashoffset="30" stroke-linecap="round"/></g>

        <!-- Edges: main concept → sub-folders -->
        <g class="p-e p-e-main-entities"><line x1="360" y1="120" x2="378" y2="108" stroke="url(#p-accent)" stroke-width="1.5" stroke-dasharray="20" stroke-dashoffset="20" stroke-linecap="round"/></g>
        <g class="p-e p-e-main-synthesis"><line x1="360" y1="166" x2="378" y2="178" stroke="url(#p-accent)" stroke-width="1.5" stroke-dasharray="20" stroke-dashoffset="20" stroke-linecap="round"/></g>

        <!-- Edges: main concept → related knowledge -->
        <g class="p-e p-e-main-rel1"><line x1="410" y1="135" x2="435" y2="105" stroke="#ccc" stroke-width="0.8" stroke-dasharray="4,3" stroke-dashoffset="28" stroke-linecap="round"/></g>
        <g class="p-e p-e-main-rel2"><line x1="410" y1="143" x2="435" y2="165" stroke="#ccc" stroke-width="0.8" stroke-dasharray="4,3" stroke-dashoffset="30" stroke-linecap="round"/></g>
        <g class="p-e p-e-main-rel3"><line x1="410" y1="150" x2="435" y2="215" stroke="#ccc" stroke-width="0.8" stroke-dasharray="4,3" stroke-dashoffset="40" stroke-linecap="round"/></g>

        <g class="p-good"><text x="360" y="298" text-anchor="middle" font-size="9" fill="#4CAF50" font-weight="500">✓ 统一 · 自链接 · 随时可检索</text></g>
      </svg>
    </SVGVisual>
  </div>
</section>

<style is:global>
  .phil-text h2 { margin-bottom: var(--space-md); }
  .phil-text p { font-size: 17px; line-height: 1.7; margin-bottom: var(--space-md); }
  .phil__points { margin-top: var(--space-md); display: flex; flex-direction: column; gap: var(--space-sm); }
  .phil__point { display: flex; align-items: flex-start; gap: var(--space-sm); font-size: 15px; color: var(--color-text-secondary); }
  .phil__dot { width: 8px; height: 8px; border-radius: 50%; background: var(--color-accent); margin-top: 6px; flex-shrink: 0; }

  :root { --spring: cubic-bezier(0.34, 1.56, 0.64, 1); }

  .p-s, .p-bad, .p-w, .p-e, .p-good { transform-box: fill-box; transform-origin: center center; }

  /* Chaotic cards: staggered entry with rotation for "messy" feel */
  .p-s { opacity: 0; }
  .svg-visual.visible .p-s1 { animation: ps-in 0.4s var(--spring) forwards; animation-delay: 0.05s; }
  .svg-visual.visible .p-s2 { animation: ps-in-r 0.4s var(--spring) forwards; animation-delay: 0.15s; }
  .svg-visual.visible .p-s3 { animation: ps-in 0.4s var(--spring) forwards; animation-delay: 0.25s; }
  .svg-visual.visible .p-s4 { animation: ps-in-r 0.4s var(--spring) forwards; animation-delay: 0.35s; }
  .svg-visual.visible .p-s5 { animation: ps-in 0.4s var(--spring) forwards; animation-delay: 0.45s; }
  .svg-visual.visible .p-s6 { animation: ps-in-r 0.4s var(--spring) forwards; animation-delay: 0.55s; }
  .svg-visual.visible .p-s7 { animation: ps-fade 0.5s ease-out forwards; animation-delay: 0.7s; }
  @keyframes ps-in { 0% { opacity: 0; transform: translateY(-8px) rotate(-3deg); } 100% { opacity: 1; transform: translateY(0) rotate(-1.5deg); } }
  @keyframes ps-in-r { 0% { opacity: 0; transform: translateY(-8px) rotate(3deg); } 100% { opacity: 1; transform: translateY(0) rotate(2deg); } }

  .p-bad { opacity: 0; }
  .svg-visual.visible .p-bad { animation: ps-fade 0.5s ease-out forwards; animation-delay: 1.3s; }
  @keyframes ps-fade { 0% { opacity: 0; } 100% { opacity: 1; } }

  /* Wiki nodes: clean slide-in from right */
  .p-w { opacity: 0; }
  .svg-visual.visible .p-w-raw { animation: pw-in 0.45s var(--spring) forwards; animation-delay: 0.8s; }
  .svg-visual.visible .p-w-inbox { animation: pw-in 0.45s var(--spring) forwards; animation-delay: 0.9s; }
  .svg-visual.visible .p-w-main { animation: pw-in 0.5s var(--spring) forwards; animation-delay: 1.0s; }
  .svg-visual.visible .p-w-entities { animation: pw-in 0.45s var(--spring) forwards; animation-delay: 1.2s; }
  .svg-visual.visible .p-w-synthesis { animation: pw-in 0.45s var(--spring) forwards; animation-delay: 1.3s; }
  .svg-visual.visible .p-w-rel1 { animation: pw-in 0.35s var(--spring) forwards; animation-delay: 1.5s; }
  .svg-visual.visible .p-w-rel2 { animation: pw-in 0.35s var(--spring) forwards; animation-delay: 1.65s; }
  .svg-visual.visible .p-w-rel3 { animation: pw-in 0.35s var(--spring) forwards; animation-delay: 1.8s; }
  @keyframes pw-in { 0% { opacity: 0; transform: translateX(14px); } 100% { opacity: 1; transform: translateX(0); } }

  .p-e { opacity: 0; }
  .svg-visual.visible .p-e-raw-inbox { animation: pe-draw 0.3s ease-out forwards; animation-delay: 0.95s; }
  .svg-visual.visible .p-e-inbox-main { animation: pe-draw 0.4s ease-out forwards; animation-delay: 1.1s; }
  .svg-visual.visible .p-e-main-entities { animation: pe-draw 0.3s ease-out forwards; animation-delay: 1.25s; }
  .svg-visual.visible .p-e-main-synthesis { animation: pe-draw 0.3s ease-out forwards; animation-delay: 1.35s; }
  .svg-visual.visible .p-e-main-rel1 { animation: pe-draw-faint 0.4s ease-out forwards; animation-delay: 1.7s; }
  .svg-visual.visible .p-e-main-rel2 { animation: pe-draw-faint 0.4s ease-out forwards; animation-delay: 1.85s; }
  .svg-visual.visible .p-e-main-rel3 { animation: pe-draw-faint 0.45s ease-out forwards; animation-delay: 2.0s; }
  @keyframes pe-draw { 0% { opacity: 1; stroke-dashoffset: inherit; } 100% { stroke-dashoffset: 0; } }
  @keyframes pe-draw-faint { 0% { opacity: 0.6; stroke-dashoffset: inherit; } 100% { opacity: 0.4; stroke-dashoffset: 0; } }

  .p-good { opacity: 0; }
  .svg-visual.visible .p-good { animation: ps-fade 0.5s ease-out forwards; animation-delay: 2.2s; }

  @media (max-width: 900px) { .phil-text { order: 0; } }
</style>
