---
import Button from '../components/Button.astro';
---
<section class="section section--surface" id="download">
  <div class="container text-center">
    <h2 class="fade-in">开始构建你的 LLM Wiki</h2>
    <p class="cta__subtitle text-secondary fade-in">macOS 15+ · Python 3.11+ · Anthropic API Key</p>
    <div class="cta__action fade-in">
      <Button href="https://github.com/NeilChenyc/piki/releases/tag/v0.1.0-beta.1">免费下载 macOS 版</Button>
    </div>
    <p class="cta__note fade-in">本地运行 · 无需注册 · 无需云服务</p>
  </div>
</section>

<style>
  .cta__subtitle {
    font-size: 17px;
    margin: var(--space-md) 0 var(--space-lg);
  }

  .cta__action {
    margin-top: var(--space-md);
  }

  .cta__note {
    margin-top: var(--space-md);
    font-size: 14px;
    color: var(--color-text-tertiary);
  }
</style>
