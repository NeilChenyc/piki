---
import SVGVisual from '../components/SVGVisual.astro';
---
<section class="section" id="knowledge-compile">
  <div class="container grid-2">
    <SVGVisual alt="知识网络从稀疏到密集">
      <svg viewBox="0 0 480 290" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="f2-shadow" x="-15%" y="-15%" width="130%" height="130%">
            <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000" flood-opacity="0.07"/>
          </filter>
          <filter id="f2-hub-glow">
            <feGaussianBlur stdDeviation="5" result="blur"/>
            <feComposite in="SourceGraphic" in2="blur" operator="over"/>
          </filter>
          <linearGradient id="f2-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#4CAF50"/><stop offset="100%" stop-color="#2E7D32"/>
          </linearGradient>
          <radialGradient id="f2-amb-l" cx="25%" cy="50%" r="40%">
            <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.04"/>
            <stop offset="100%" stop-color="#4CAF50" stop-opacity="0"/>
          </radialGradient>
          <radialGradient id="f2-amb-r" cx="75%" cy="50%" r="45%">
            <stop offset="0%" stop-color="#4CAF50" stop-opacity="0.06"/>
            <stop offset="100%" stop-color="#4CAF50" stop-opacity="0"/>
          </radialGradient>
          <pattern id="f2-dots" width="26" height="26" patternUnits="userSpaceOnUse">
            <circle cx="13" cy="13" r="0.7" fill="#4CAF50" opacity="0.05"/>
          </pattern>
        </defs>

        <rect width="480" height="290" fill="url(#f2-dots)"/>
        <circle cx="120" cy="145" r="150" fill="url(#f2-amb-l)"/>
        <circle cx="375" cy="145" r="160" fill="url(#f2-amb-r)"/>

        <!-- Phase labels -->
        <g class="f2-label f2-l1"><text x="30" y="22" font-size="10" fill="#aaa">初次积累</text></g>

        <!-- Phase 1: Sparse -->
        <circle class="f2-sn f2-s0" cx="68" cy="130" r="18" fill="white" stroke="#ddd" stroke-width="1.5" filter="url(#f2-shadow)"/>
        <text class="f2-sn f2-s0" x="68" y="134" text-anchor="middle" font-size="10" fill="#888">技术创新史</text>

        <circle class="f2-sn f2-s1" cx="155" cy="62" r="14" fill="white" stroke="#ddd" stroke-width="1.2" filter="url(#f2-shadow)"/>
        <text class="f2-sn f2-s1" x="155" y="66" text-anchor="middle" font-size="9" fill="#bbb">半导体演进</text>

        <circle class="f2-sn f2-s2" cx="175" cy="172" r="15" fill="white" stroke="#ddd" stroke-width="1.2" filter="url(#f2-shadow)"/>
        <text class="f2-sn f2-s2" x="175" y="176" text-anchor="middle" font-size="9" fill="#bbb">商业模式变革</text>

        <circle class="f2-sn f2-s3" cx="50" cy="225" r="12" fill="white" stroke="#ddd" stroke-width="1.2" filter="url(#f2-shadow)"/>
        <text class="f2-sn f2-s3" x="50" y="229" text-anchor="middle" font-size="8" fill="#bbb">关键人物</text>

        <line class="f2-se" x1="82" y1="120" x2="141" y2="74" stroke="#ddd" stroke-width="1"/>
        <line class="f2-se" x1="86" y1="138" x2="161" y2="163" stroke="#ddd" stroke-width="1"/>
        <line class="f2-se" x1="57" y1="146" x2="52" y2="213" stroke="#ddd" stroke-width="1"/>

        <!-- Arrow -->
        <g class="f2-arrow">
          <path d="M 198,140 L 258,140" stroke="#bbb" stroke-width="2" stroke-dasharray="6,4"/>
          <polygon points="258,135 266,140 258,145" fill="#bbb"/>
        </g>

        <g class="f2-label f2-l2"><text x="295" y="22" font-size="10" fill="#4CAF50">持续编译后</text></g>

        <!-- Phase 2: Dense -->
        <circle class="f2-dn f2-d0" cx="375" cy="135" r="24" fill="white" stroke="url(#f2-grad)" stroke-width="2.5" filter="url(#f2-hub-glow)"/>
        <text class="f2-dn f2-d0" x="375" y="131" text-anchor="middle" font-size="11" fill="#2E7D32" font-weight="600">信息技术</text>
        <text class="f2-dn f2-d0" x="375" y="148" text-anchor="middle" font-size="8" fill="#4CAF50">革命史</text>

        <circle class="f2-dn f2-d1" cx="298" cy="52" r="16" fill="white" stroke="url(#f2-grad)" stroke-width="1.8" filter="url(#f2-shadow)"/>
        <text class="f2-dn f2-d1" x="298" y="56" text-anchor="middle" font-size="9" fill="#333">芯片技术</text>

        <circle class="f2-dn f2-d2" cx="458" cy="58" r="16" fill="white" stroke="url(#f2-grad)" stroke-width="1.8" filter="url(#f2-shadow)"/>
        <text class="f2-dn f2-d2" x="458" y="62" text-anchor="middle" font-size="9" fill="#333">软件工程</text>

        <circle class="f2-dn f2-d3" cx="315" cy="230" r="15" fill="white" stroke="url(#f2-grad)" stroke-width="1.8" filter="url(#f2-shadow)"/>
        <text class="f2-dn f2-d3" x="315" y="234" text-anchor="middle" font-size="9" fill="#333">企业变革</text>

        <circle class="f2-dn f2-d4" cx="448" cy="225" r="15" fill="white" stroke="url(#f2-grad)" stroke-width="1.8" filter="url(#f2-shadow)"/>
        <text class="f2-dn f2-d4" x="448" y="229" text-anchor="middle" font-size="9" fill="#333">政策影响</text>

        <circle class="f2-dn f2-d5" cx="275" cy="140" r="11" fill="white" stroke="#C8E6C9" stroke-width="1.3" filter="url(#f2-shadow)"/>
        <text class="f2-dn f2-d5" x="275" y="144" text-anchor="middle" font-size="7" fill="#888">人物志</text>

        <circle class="f2-dn f2-d6" cx="476" cy="140" r="11" fill="white" stroke="#C8E6C9" stroke-width="1.3" filter="url(#f2-shadow)"/>
        <text class="f2-dn f2-d6" x="476" y="144" text-anchor="middle" font-size="7" fill="#888">书摘</text>

        <circle class="f2-dn f2-d7" cx="375" cy="262" r="12" fill="white" stroke="#C8E6C9" stroke-width="1.3" filter="url(#f2-shadow)"/>
        <text class="f2-dn f2-d7" x="375" y="266" text-anchor="middle" font-size="7" fill="#888">阅读来源</text>

        <!-- Dense edges -->
        <line class="f2-de" x1="311" y1="64" x2="354" y2="116" stroke="#4CAF50" stroke-width="1.3" opacity="0.6"/>
        <line class="f2-de" x1="442" y1="71" x2="394" y2="116" stroke="#4CAF50" stroke-width="1.3" opacity="0.6"/>
        <line class="f2-de" x1="330" y1="217" x2="364" y2="155" stroke="#4CAF50" stroke-width="1.3" opacity="0.6"/>
        <line class="f2-de" x1="432" y1="212" x2="394" y2="155" stroke="#4CAF50" stroke-width="1.3" opacity="0.6"/>
        <line class="f2-de" x1="285" y1="138" x2="351" y2="135" stroke="#C8E6C9" stroke-width="0.9"/>
        <line class="f2-de" x1="399" y1="135" x2="465" y2="138" stroke="#C8E6C9" stroke-width="0.9"/>
        <line class="f2-de" x1="375" y1="159" x2="375" y2="250" stroke="#C8E6C9" stroke-width="0.9"/>
      </svg>
    </SVGVisual>
    <div class="feature-text fade-in">
      <h2>碎片进去，Wiki 出来</h2>
      <p class="text-secondary">拖入资料，Agent 拆解为来源页、概念页、实体页，自动挂载到正确位置。</p>
      <p class="text-secondary">新信息不是堆在旁边——而是融入已有页面，建立双向链接。结构越用越完整。</p>
      <div class="feature__path"><code>sources/ → concepts/ → entities/ → synthesis/</code></div>
    </div>
  </div>
</section>

<style is:global>
  .feature-text h2 { margin-bottom: var(--space-md); }
  .feature-text p { font-size: 17px; line-height: 1.7; margin-bottom: var(--space-md); }
  .feature__path { margin-top: var(--space-md); }
  .feature__path code { font-family: var(--font-mono); font-size: 14px; color: var(--color-accent-dark); background: var(--color-accent-light); padding: var(--space-xs) var(--space-sm); border-radius: var(--radius-sm); }

  .f2-sn, .f2-dn, .f2-label, .f2-arrow { transform-box: fill-box; transform-origin: center center; }

  .f2-label, .f2-arrow { opacity: 0; }
  .svg-visual.visible .f2-l1 { animation: f2-fade 0.4s ease-out forwards; animation-delay: 0.1s; }
  @keyframes f2-fade { 0% { opacity: 0; } 100% { opacity: 1; } }

  .f2-sn, .f2-se { opacity: 0; }
  .svg-visual.visible .f2-s0 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 0.2s; }
  .svg-visual.visible .f2-s1 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 0.35s; }
  .svg-visual.visible .f2-s2 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 0.5s; }
  .svg-visual.visible .f2-s3 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 0.65s; }
  @keyframes f2-pop { 0% { opacity: 0; transform: scale(0); } 100% { opacity: 1; transform: scale(1); } }

  .svg-visual.visible .f2-se { animation: f2-fade 0.25s ease-out forwards; }
  .svg-visual.visible .f2-se:nth-of-type(5) { animation-delay: 0.55s; }
  .svg-visual.visible .f2-se:nth-of-type(6) { animation-delay: 0.7s; }
  .svg-visual.visible .f2-se:nth-of-type(7) { animation-delay: 0.85s; }

  .svg-visual.visible .f2-arrow { animation: f2-fade 0.5s ease-out forwards; animation-delay: 1.1s; }
  .svg-visual.visible .f2-l2 { animation: f2-fade 0.4s ease-out forwards; animation-delay: 1.3s; }

  .f2-dn, .f2-de { opacity: 0; }
  .svg-visual.visible .f2-d0 { animation: f2-pop 0.55s var(--spring) forwards; animation-delay: 1.5s; }
  .svg-visual.visible .f2-d1 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 1.7s; }
  .svg-visual.visible .f2-d2 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 1.85s; }
  .svg-visual.visible .f2-d3 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 2.0s; }
  .svg-visual.visible .f2-d4 { animation: f2-pop 0.45s var(--spring) forwards; animation-delay: 2.15s; }
  .svg-visual.visible .f2-d5 { animation: f2-pop 0.35s var(--spring) forwards; animation-delay: 2.3s; }
  .svg-visual.visible .f2-d6 { animation: f2-pop 0.35s var(--spring) forwards; animation-delay: 2.4s; }
  .svg-visual.visible .f2-d7 { animation: f2-pop 0.35s var(--spring) forwards; animation-delay: 2.5s; }

  .svg-visual.visible .f2-de { animation: f2-fade 0.2s ease-out forwards; }
  .svg-visual.visible .f2-de:nth-of-type(18) { animation-delay: 2.0s; }
  .svg-visual.visible .f2-de:nth-of-type(19) { animation-delay: 2.15s; }
  .svg-visual.visible .f2-de:nth-of-type(20) { animation-delay: 2.3s; }
  .svg-visual.visible .f2-de:nth-of-type(21) { animation-delay: 2.45s; }
  .svg-visual.visible .f2-de:nth-of-type(22) { animation-delay: 2.6s; }
  .svg-visual.visible .f2-de:nth-of-type(23) { animation-delay: 2.7s; }
  .svg-visual.visible .f2-de:nth-of-type(24) { animation-delay: 2.8s; }
</style>
